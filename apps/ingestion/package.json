{
  "dependencies": {
    "@congress/database": "workspace:*",
    "oboe": "^2.1.5",
    "p-defer": "^4.0.1",
    "p-deferred": "^1.0.0",
    "p-limit": "^7.2.0",
    "p-queue": "^9.0.1",
    "p-retry": "^7.1.1",
    "playwright": "^1.55.0",
    "rxjs": "^7.8.2",
    "sqlite3": "^5.1.7",
    "zod": "^4.0.17"
  },
  "description": "",
  "devDependencies": {
    "@types/oboe": "^2.1.4"
  },
  "main": "index.js",
  "name": "@congress/ingestion",
  "private": true,
  "scripts": {
    "format": "pnpm run format:ci --write",
    "format:ci": "prettier --ignore-unknown --list-different \"**/*\"",
    "lint": "pnpm run lint:style && pnpm run lint:types",
    "lint:ci": "pnpm run lint:style --max-warnings 0 && pnpm run lint:types",
    "lint:style": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "lint:types": "tsc --noEmit --project tsconfig.json",
    "scrape": "tsx src/main.ts",
    "scrape:person": "tsx src/main.ts --source=person",
    "scrape:voting": "tsx src/main.ts --source=voting",
    "scrape:intervention": "tsx src/main.ts --source=intervention",
    "scrape:bureau": "tsx src/main.ts --source=bureau",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:integration": "node --import tsx/esm src/test/finders.test.ts",
    "test:retrievers": "node --import tsx/esm src/test/retrievers.test.ts"
  },
  "type": "module",
  "version": "1.0.0"
}

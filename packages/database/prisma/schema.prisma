generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

/// Represents an individual in the Spanish Congress (deputy, speaker, or official).
/// Serves as the identity anchor for person-centric data. Deputies, interventions, and bureau
/// members link to Person after entity resolution. Name is the natural key for deduplication.
///
/// Data source: person.ts scraper (DiputadosActivos JSON)
model Person {
  id            String   @id @default(cuid())
  /// Full name of the person. Used as the natural key for deduplication across sources.
  name          String
  /// Optional biography text from official congress profile.
  biography     String?
  /// Date of birth.
  birthDate     DateTime?
  /// URL to official congress profile photo.
  photoUrl      String?
  /// Official congress email address.
  email         String?
  /// Facebook profile URL.
  facebook      String?
  /// Instagram profile URL.
  instagram     String?
  /// LinkedIn profile URL.
  linkedin      String?
  /// Twitter/X profile URL.
  twitter       String?
  /// Personal website URL.
  web           String?
  /// Timestamp of record creation.
  createdAt     DateTime @default(now())
  /// Timestamp of last record update.
  updatedAt     DateTime @updatedAt

  /// Linked entities.
  deputies      Deputy[]
  interventions Intervention[]
  organMembers OrganMember[]

  /// Ensures one Person record per unique name. Deduplicates across multiple data sources.
  /// Known limitation: two deputies with identical names will collide into one record.
  /// Acceptable at ~350 deputies per legislature — statistically unlikely and handled manually
  /// if it occurs. A proper fix would use the official congress deputy ID as the natural key.
  @@unique([name])
}

/// Represents a political party in the Spanish Congress.
/// Tracks party metadata for deputy affiliations and historical records.
///
/// Data source: party.ts scraper
model Party {
  id        String   @id @default(cuid())
  /// Full official name of the party (e.g. "Partido Popular").
  name      String
  /// Abbreviated party name or acronym from opendata (e.g. "PP"). Used as the natural key.
  shortName String   @unique
  /// Optional reference to canonical parent party for regional branches (e.g. PSC-PSOE → PSOE).
  parentId  String?
  /// Timestamp of record creation.
  createdAt DateTime @default(now())
  /// Timestamp of last record update.
  updatedAt DateTime @updatedAt

  /// Self-relation for canonical parent party.
  parent   Party?  @relation("PartyAffiliation", fields: [parentId], references: [id])
  children Party[] @relation("PartyAffiliation")

  /// Linked entities.
  deputies     Deputy[]
}

/// Represents a person's term as a parliamentary deputy in a specific legislature.
/// Captures deputy metadata including electoral and parliamentary group information.
/// A person may have multiple Deputy records across different legislatures if re-elected.
///
/// Data source: person.ts scraper (DiputadosActivos JSON)
model Deputy {
  id                  String   @id @default(cuid())
  /// Reference to the Person who holds this deputy seat.
  personId            String
  /// Optional reference to the Party. Null until entity resolution is complete.
  /// Some deputies may not have a matched party entity initially.
  partyId             String?
  /// Electoral district/constituency the deputy represents.
  constituency        String
  /// Date deputy assumed office in this legislature.
  startDate           DateTime
  /// Date deputy achieved full voting rights. May differ from startDate for substitutes
  /// who initially served in a limited capacity. Null if not applicable or unknown.
  fullConditionDate   DateTime?
  /// Parliamentary group (Grupo Parlamentario) the deputy belongs to. May differ from
  /// electoral formation due to political realignments post-election.
  parliamentaryGroup  String
  /// Electoral coalition or list the deputy was elected under.
  electoralFormation  String
  /// Legislature number. Defaults to 15 (current legislature as of 2026-01).
  /// Used for historical data partitioning across multiple legislatures.
  legislature         Int      @default(15)
  /// Timestamp of record creation.
  createdAt           DateTime @default(now())
  /// Timestamp of last record update.
  updatedAt           DateTime @updatedAt

  /// Linked entities.
  person              Person   @relation(fields: [personId], references: [id])
  party               Party?   @relation(fields: [partyId], references: [id])
  interestDeclarations InterestDeclaration[]

  /// Ensures one deputy record per person, per legislature, per term start.
  /// Allows same person to serve multiple non-consecutive terms if re-elected.
  @@unique([personId, legislature, startDate])
}

/// Represents a plenary voting session with aggregate results.
/// Contains session-level metadata and denormalized vote counts for efficient analytics.
/// Individual votes are stored separately in the Vote model.
///
/// Data source: voting.ts scraper (Votaciones JSON)
model VotingSession {
  id                String   @id @default(cuid())
  /// Legislature number for historical partitioning.
  legislature       Int
  /// Session sequence number within the legislature.
  sessionNumber     Int
  /// Voting number within the session.
  votingNumber      Int
  /// Date and time of the voting session.
  votingDate        DateTime
  /// Title or subject of the vote (e.g., "Proyecto de Ley...").
  title             String
  /// Extended description or voting topic details.
  description       String
  /// True if motion passed by unanimous consent without individual recorded votes.
  /// When true, individual Vote records may not be available.
  byAssent          Boolean  @default(false)
  /// Denormalized: Total deputies present during the vote.
  /// Enables efficient analytics without aggregating Vote table.
  totalPresent      Int
  /// Denormalized: Deputies who voted affirmatively.
  totalFor          Int
  /// Denormalized: Deputies who voted negatively.
  totalAgainst      Int
  /// Denormalized: Deputies who abstained.
  totalAbstention   Int
  /// Denormalized: Deputies who did not vote.
  totalNoVote       Int
  /// URL to the original JSON data source for audit trail.
  sourceUrl         String
  /// Timestamp of record creation.
  createdAt         DateTime @default(now())
  /// Timestamp of last record update.
  updatedAt         DateTime @updatedAt

  /// Linked entities.
  votes             Vote[]

  /// Ensures one session per legislature/session/voting combination.
  /// Natural key: (legislature, sessionNumber, votingNumber).
  @@unique([legislature, sessionNumber, votingNumber])
}

/// Represents an individual deputy's vote in a voting session.
/// Uses denormalized string fields (deputy name, group) to preserve historical record:
/// deputies may change groups, be removed from office, or reconciliation with Person
/// records may fail after the vote was cast. This model captures the vote exactly as cast.
///
/// Note: No direct relationship to Person/Deputy models. Uses deputySeat and deputyName
/// as historical identifiers. Deputy reconciliation happens at analysis time, not storage.
///
/// Data source: voting.ts scraper (Votaciones JSON)
model Vote {
  id              String        @id @default(cuid())
  /// Reference to the VotingSession this vote belongs to.
  sessionId       String
  /// Seat identifier (e.g., deputy number or seat designation) at time of vote.
  deputySeat      String
  /// Deputy name as recorded in voting record. Denormalized for historical accuracy.
  deputyName      String
  /// Parliamentary group (Grupo Parlamentario) at time of vote. Denormalized as
  /// deputies may change groups between votes.
  deputyGroup     String
  /// Vote value: "Sí" (affirmative), "No" (negative), "Abstención" (abstention),
  /// or "No vota" (did not vote).
  vote            String
  /// Timestamp of record creation.
  createdAt       DateTime      @default(now())
  /// Timestamp of last record update.
  updatedAt       DateTime      @updatedAt

  /// Linked entities.
  session         VotingSession @relation(fields: [sessionId], references: [id])

  /// Ensures one vote record per deputy per session.
  @@unique([sessionId, deputySeat])
}

/// Represents a parliamentary intervention (speech) in a session.
/// Metadata comes from the bulk intervention JSON (intervention pipeline).
/// Text content comes from the HTML session transcript (intervention-detail pipeline).
/// Both sources are merged in a processor before storage — no partial records.
///
/// Data source: intervention.ts + intervention-detail.ts scrapers
model Intervention {
  id              String   @id @default(cuid())
  /// Optional reference to Person. Null until entity resolution matches speaker name.
  personId        String?
  /// Session identifier derived from the transcript URL (e.g. "DSCD-15-PL-1.CODI.").
  sessionId       String
  /// Date of the parliamentary session.
  sessionDate     DateTime
  /// Title or topic of the session.
  sessionTitle    String
  /// URL to the original session transcript page (without fragment).
  sessionUrl      String
  /// Raw speaker text as extracted from source (e.g. "El señor GARCÍA GARCÍA:").
  speakerRaw      String
  /// Parsed speaker name. Used for Person reconciliation.
  speakerName     String
  /// Speaker role or title (e.g. "Presidente", "Diputado"). Null if not specified.
  speakerRole     String?
  /// Full text of the intervention.
  text            String
  /// Sequential order within the session.
  orderInSession  Int
  /// Parliamentary organ where the intervention took place.
  organ           String?
  /// Description of the initiative being discussed.
  initiativeSubject String?
  /// Intervention type (e.g. "Intervención", "Réplica").
  interventionType  String?
  /// Start time of the intervention (HH:MM:SS format from bulk JSON).
  startTime       String?
  /// End time of the intervention (HH:MM:SS format from bulk JSON).
  endTime         String?
  /// URL to deferred video recording.
  videoUrl        String?
  /// URL to direct video download.
  videoDownloadUrl String?
  /// Timestamp of record creation.
  createdAt       DateTime @default(now())
  /// Timestamp of last record update.
  updatedAt       DateTime @updatedAt

  /// Linked entities.
  person          Person?  @relation(fields: [personId], references: [id])

  /// Ensures one intervention record per session order. Sessions may have multiple
  /// interventions; orderInSession tracks their sequence for historical reconstruction.
  @@unique([sessionId, orderInSession])
}

/// Represents a person's service in any congressional organ or committee position.
/// Covers Mesa del Congreso, parliamentary committees (Comisiones), Junta de
/// Portavoces, Diputación Permanente, and any other organ. Previously named
/// BureauMember — renamed to reflect that all organs are captured, not just
/// the bureau (Mesa).
///
/// Data source: bureau.ts scraper (Organos JSON)
model OrganMember {
  id          String    @id @default(cuid())
  /// Optional reference to Person. Null until entity resolution matches member name
  /// to Person records. Some members may not reconcile (deceased prior members in records).
  personId    String?
  /// Full name of the organ member. Denormalized for historical preservation.
  name        String
  /// Position held (e.g., "Presidente", "Vicepresidente", "Secretario", "Vocal").
  position    String
  /// Congressional organ/committee name (e.g., "Mesa del Congreso", "Junta de Portavoces").
  organ       String
  /// Discriminator for the type of organ. Derived from the organ name during ingestion.
  /// Values: MESA | COMISION | JUNTA_PORTAVOCES | DIPUTACION_PERMANENTE | OTHER
  organType   String    @default("OTHER")
  /// Parliamentary group (Grupo Parlamentario) at time of appointment.
  partyGroup  String
  /// Date position started.
  startDate   DateTime
  /// Date position ended. Null for currently serving members.
  endDate     DateTime?
  /// Timestamp of record creation.
  createdAt   DateTime  @default(now())
  /// Timestamp of last record update.
  updatedAt   DateTime  @updatedAt

  /// Linked entities.
  person      Person?   @relation(fields: [personId], references: [id])

  /// Ensures one appointment record per name/organ/position/start combination.
  /// Allows same person to hold multiple positions and enables re-appointment after gaps.
  @@unique([name, organ, position, startDate])
}

/// Tracks scraper execution metadata for monitoring and retry management.
/// Maintains state for the ingestion pipeline including success/failure tracking,
/// retry counts, and last execution timestamps. Each scraper type has one record.
///
/// Used by the ingestion pipeline (apps/ingestion/src/main.ts) for:
/// - Recording successful and failed scraper runs via updateScraperMetadata
/// - Exposing run history for monitoring and diagnostics
///
/// Data source: Updated by apps/ingestion/src/main.ts after each pipeline run
model ScraperMetadata {
  id                  String   @id @default(cuid())
  /// Unique identifier for the scraper type (e.g., "person", "voting", "intervention", "bureau").
  /// Maps to specific scraper implementation.
  scraperType         String   @unique
  /// Timestamp of last successful scraper execution. Used to schedule next run.
  /// Null if scraper has never run successfully.
  lastSuccessfulRun   DateTime?
  /// Timestamp of last attempted execution (successful or failed).
  /// Used to detect stalled scrapers.
  lastAttemptedRun    DateTime?
  /// Number of consecutive retry attempts. Reset to 0 on successful run.
  /// Used for exponential backoff calculation in retry logic.
  attemptCount        Int      @default(0)
  /// Error message from last failed execution. Null if last run succeeded.
  /// Preserved for debugging and alerting.
  lastError           String?
  /// Timestamp of record creation.
  createdAt           DateTime @default(now())
  /// Timestamp of last record update.
  updatedAt           DateTime @updatedAt

  /// Index on scraperType for efficient lookups during job scheduling decisions.
  @@index([scraperType])
}

/// Type of legislative initiative.
enum InitiativeType {
  /// Ley — enacted law passed by Parliament.
  LAW
  /// Ley orgánica — organic law requiring absolute majority.
  ORGANIC_LAW
  /// Real Decreto-ley — emergency royal decree with force of law.
  ROYAL_DECREE
  /// Proyecto de Ley — government-sponsored bill.
  BILL
  /// Proposición de Ley de Diputados — private member bill.
  PRIVATE_MEMBER_BILL
  /// Proposición de Ley de Grupos Parlamentarios — parliamentary group bill.
  PARLIAMENTARY_GROUP_BILL
  /// Proposición de Ley de Comunidades Autónomas — autonomous community bill.
  AUTONOMOUS_COMMUNITY_BILL
  /// Proposición de Ley del Senado — senate bill.
  SENATE_BILL
  /// Propuesta de reforma de Estatuto de Autonomía — statute reform proposal.
  STATUTE_REFORM
}

/// Represents an approved or in-progress legislative initiative from the Spanish Congress.
/// Covers Proyectos de Ley, Proposiciones de Ley, Real Decreto-ley, and other initiative
/// types published in the congreso.es Iniciativas open data dataset.
///
/// Data source: initiatives.ts scraper (Iniciativas JSON)
model Initiative {
  id                   String    @id @default(cuid())
  /// Legislature number for historical partitioning.
  legislature          Int
  /// Initiative type — normalised enum value derived from the source Spanish string.
  type                 InitiativeType
  /// Initiative title. OBJETO for parliamentary bills, TITULO_LEY for approved laws.
  title                String
  /// Parliamentary expedient number (e.g. "121/000009/0000").
  /// Present for ProyectosDeLey, ProposicionesDeLey, PropuestasDeReforma.
  /// Null for Reales decretos (no parliamentary process).
  expedienteNumero     String?
  /// BOE bulletin number. Present for Reales decretos and enacted laws.
  /// Populated via title-match enrichment for parliamentary bills.
  bulletinNumber       String?
  /// Date of official gazette publication.
  bulletinDate         DateTime?
  /// Law number (e.g. "9" for Ley 9/2025). Null until enriched.
  number               String?
  /// Date the initiative was enacted into law. Null until enriched.
  enactedDate          DateTime?
  /// URL to the official PDF. Null until enriched.
  pdfUrl               String?
  /// Date the parliamentary bill was submitted. Null for approved laws and Reales decretos.
  presentedDate        DateTime?
  /// Current parliamentary status (e.g. "Cerrado", "Comisión de Justicia\nInforme").
  /// Null for Reales decretos.
  situacion            String?
  /// Parliamentary outcome (e.g. "Aprobado con modificaciones\n16/12/2025").
  /// Null for Reales decretos.
  resultadoTramitacion String?
  /// Timestamp of record creation.
  createdAt            DateTime  @default(now())
  /// Timestamp of last record update.
  updatedAt            DateTime  @updatedAt

  @@unique([legislature, expedienteNumero])
  @@unique([legislature, bulletinNumber])
}

/// Represents a deputy's annual financial interest declaration (Registro de Intereses).
/// Each deputy files one declaration per year. Asset categories are normalized into
/// separate child tables for queryability.
///
/// Data source: interestDeclarations.ts scraper (Registro de Intereses JSON/XML)
model InterestDeclaration {
  id           String   @id @default(cuid())
  /// Reference to the Deputy who filed this declaration.
  deputyId     String
  /// Declaration year (e.g., 2024).
  year         Int
  /// URL to the official PDF declaration. May be null if only structured data available.
  pdfUrl       String?
  /// Timestamp of record creation.
  createdAt    DateTime @default(now())
  /// Timestamp of last record update.
  updatedAt    DateTime @updatedAt

  /// Linked entities.
  deputy                 Deputy                 @relation(fields: [deputyId], references: [id])
  realEstateAssets       RealEstateAsset[]
  movableAssets          MovableAsset[]
  securities             Security[]
  bankAccounts           BankAccount[]
  professionalActivities ProfessionalActivity[]
  incomeSources          IncomeSource[]
  donations              Donation[]
  foundations            Foundation[]
  observations           Observation[]

  /// One declaration per deputy per year.
  @@unique([deputyId, year])
}

/// Real estate property declared by a deputy (Bienes inmuebles).
model RealEstateAsset {
  id               String              @id @default(cuid())
  declarationId    String
  /// Property type (e.g., "Vivienda", "Garaje", "Terreno").
  propertyType     String
  /// Street address. May be partially redacted in source data.
  address          String?
  /// Surface area in square metres.
  surface          Float?
  /// Year of acquisition.
  acquisitionYear  Int?
  /// Value at time of acquisition in EUR.
  acquisitionValue Float?
  /// Current cadastral or market value in EUR.
  currentValue     Float?
  /// Outstanding mortgage balance in EUR. Null if unencumbered.
  mortgage         Float?
  /// Timestamp of record creation.
  createdAt        DateTime            @default(now())
  /// Timestamp of last record update.
  updatedAt        DateTime            @updatedAt
  /// Linked entities.
  declaration   InterestDeclaration @relation(fields: [declarationId], references: [id])
}

/// Gift or donation received by a deputy (Donaciones y regalos).
/// Source: TIPO=DONACION rows in the docacteco bulk JSON.
model Donation {
  id            String              @id @default(cuid())
  declarationId String
  /// Description of the gift or donation.
  description   String
  /// Name of the person or entity who gave the gift. Null if not specified.
  benefactor    String?
  /// Timestamp of record creation.
  createdAt     DateTime            @default(now())
  /// Timestamp of last record update.
  updatedAt     DateTime            @updatedAt

  /// Linked entities.
  declaration   InterestDeclaration @relation(fields: [declarationId], references: [id])
}

/// Foundation or association membership/contribution declared by a deputy (Fundaciones y asociaciones).
/// Source: TIPO=FUNDACIONES rows in the docacteco bulk JSON.
model Foundation {
  id            String              @id @default(cuid())
  declarationId String
  /// Name of the foundation or association receiving the contribution.
  recipient     String
  /// Description of the contribution or membership type.
  description   String?
  /// Timestamp of record creation.
  createdAt     DateTime            @default(now())
  /// Timestamp of last record update.
  updatedAt     DateTime            @updatedAt

  /// Linked entities.
  declaration   InterestDeclaration @relation(fields: [declarationId], references: [id])
}

/// Free-text observation added by a deputy to their interest declaration.
/// Source: TIPO=OBSERVACIONES rows in the docacteco bulk JSON.
model Observation {
  id            String              @id @default(cuid())
  declarationId String
  /// Full text of the observation.
  text          String
  /// Timestamp of record creation.
  createdAt     DateTime            @default(now())
  /// Timestamp of last record update.
  updatedAt     DateTime            @updatedAt

  /// Linked entities.
  declaration   InterestDeclaration @relation(fields: [declarationId], references: [id])
}


/// Movable asset declared by a deputy (Bienes muebles — vehicles, boats, art, etc.).
model MovableAsset {
  id              String              @id @default(cuid())
  declarationId   String
  /// Asset type (e.g., "Vehículo", "Embarcación", "Obra de arte").
  assetType       String
  /// Description (make/model or free-text description).
  description     String?
  /// Year of acquisition.
  acquisitionYear Int?
  /// Estimated value in EUR.
  value           Float?
  /// Timestamp of record creation.
  createdAt       DateTime            @default(now())
  /// Timestamp of last record update.
  updatedAt       DateTime            @updatedAt

  /// Linked entities.
  declaration     InterestDeclaration @relation(fields: [declarationId], references: [id])
}

/// Securities (stocks, bonds, funds) declared by a deputy (Valores mobiliarios).
model Security {
  id              String              @id @default(cuid())
  declarationId   String
  /// Issuing entity (company, fund, or government).
  issuer          String
  /// Security type (e.g., "Acciones", "Fondos de inversión", "Deuda pública").
  securityType    String
  /// Year of acquisition.
  acquisitionYear Int?
  /// Nominal value in EUR.
  nominalValue    Float?
  /// Current market value in EUR.
  marketValue     Float?
  /// Timestamp of record creation.
  createdAt       DateTime            @default(now())
  /// Timestamp of last record update.
  updatedAt       DateTime            @updatedAt

  /// Linked entities.
  declaration     InterestDeclaration @relation(fields: [declarationId], references: [id])
}

/// Bank account declared by a deputy (Cuentas bancarias).
/// Source data provides balance ranges rather than exact amounts.
model BankAccount {
  id            String              @id @default(cuid())
  declarationId String
  /// Financial institution name.
  institution   String
  /// Account type (e.g., "Corriente", "Ahorro", "Plazo fijo").
  accountType   String
  /// Balance range string as reported in source (e.g., "Entre 6.000 y 30.000 €").
  balanceRange  String?
  /// Timestamp of record creation.
  createdAt     DateTime            @default(now())
  /// Timestamp of last record update.
  updatedAt     DateTime            @updatedAt

  /// Linked entities.
  declaration   InterestDeclaration @relation(fields: [declarationId], references: [id])
}

/// Professional activity declared by a deputy (Actividades profesionales).
model ProfessionalActivity {
  id            String              @id @default(cuid())
  declarationId String
  /// Name of the organisation or entity where the activity takes place.
  entity        String
  /// Role or position held.
  position      String
  /// Date the activity started. Null if not specified.
  startDate     DateTime?
  /// Date the activity ended. Null if currently active.
  endDate       DateTime?
  /// Whether the activity is remunerated.
  remunerated   Boolean
  /// Timestamp of record creation.
  createdAt     DateTime            @default(now())
  /// Timestamp of last record update.
  updatedAt     DateTime            @updatedAt

  /// Linked entities.
  declaration   InterestDeclaration @relation(fields: [declarationId], references: [id])
}

/// Income source declared by a deputy (Fuentes de ingresos).
/// Source data provides amount ranges rather than exact figures.
model IncomeSource {
  id            String              @id @default(cuid())
  declarationId String
  /// Entity or person providing the income.
  source        String
  /// Nature of the income (e.g., "Salario", "Dividendos", "Arrendamiento").
  concept       String
  /// Amount range string as reported in source (e.g., "Entre 30.001 y 60.000 €").
  amountRange   String?
  /// Timestamp of record creation.
  createdAt     DateTime            @default(now())
  /// Timestamp of last record update.
  updatedAt     DateTime            @updatedAt

  /// Linked entities.
  declaration   InterestDeclaration @relation(fields: [declarationId], references: [id])
}
